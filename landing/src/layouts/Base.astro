---
interface Props {
  title: string
  description?: string
}
const { title, description = 'PodDeck — Podcast slide decks generated by Claude Code' } = Astro.props
---

<!doctype html>
<html lang="zh">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="description" content={description} />
    <title>{title}</title>
  </head>
  <body class="bg-stone-50 text-stone-900 antialiased min-h-screen">
    <header class="border-b border-stone-200 bg-white">
      <div class="max-w-6xl mx-auto px-6 py-4 flex items-center justify-between">
        <a href="/" class="font-serif text-2xl tracking-tight">
          <span class="font-bold">Pod</span>Deck
        </a>
        <nav class="text-sm text-stone-600 space-x-6">
          <a href="/" class="hover:text-stone-900">首页</a>
          <a href="/sources" class="hover:text-stone-900">源头</a>
          <a href="/tags" class="hover:text-stone-900">标签</a>
        </nav>
      </div>
    </header>
    <main class="max-w-6xl mx-auto px-6 py-10">
      <slot />
    </main>
    <footer class="mt-20 border-t border-stone-200 py-6 text-center text-xs text-stone-400">
      PodDeck · 由 Claude Code 自动生成 · Slidev + Astro
    </footer>
  </body>
</html>

<style is:global>
  :root {
    color-scheme: light;
  }
  html {
    font-family: ui-sans-serif, system-ui, -apple-system, "Segoe UI", Roboto, "PingFang SC", "Microsoft YaHei", sans-serif;
  }
  body {
    font-feature-settings: "cv11", "ss01";
  }
</style>
