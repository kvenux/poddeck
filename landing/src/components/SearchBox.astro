---
import type { EpisodeWithSource } from '../lib/data'

interface Props {
  episodes: EpisodeWithSource[]
}

const { episodes } = Astro.props

// Build a minimal search index — title + guest + summary + tags + source name
const index = episodes.map(e => ({
  id: e.id,
  base: e.base,
  title: e.title,
  guest: e.guest || '',
  guest_role: e.guest_role || '',
  source: e.sourceRef.name,
  source_color: e.sourceRef.color || '#525252',
  tags: e.tags || [],
  summary: (e.summary || '').replace(/\n/g, ' ').slice(0, 200),
  status: e.status,
  thumbnail: e.thumbnail || `https://img.youtube.com/vi/${e.id}/hqdefault.jpg`,
  // searchable haystack — lowercase, all fields concatenated
  _hay: [
    e.title,
    e.guest,
    e.guest_role,
    e.sourceRef.name,
    ...(e.tags || []),
    e.summary || '',
  ].filter(Boolean).join(' ').toLowerCase(),
}))
---

<div class="relative mb-8" id="search-root">
  <input
    type="text"
    id="search-input"
    placeholder="搜索 episode 标题、嘉宾、标签..."
    class="w-full px-4 py-3 pl-10 bg-white border border-stone-200 rounded-lg focus:border-blue-400 focus:outline-none focus:ring-2 focus:ring-blue-100 transition-all text-sm"
    autocomplete="off"
  />
  <svg class="absolute left-3 top-1/2 -translate-y-1/2 w-4 h-4 text-stone-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
  </svg>

  <!-- Results dropdown -->
  <div
    id="search-results"
    class="absolute left-0 right-0 top-full mt-2 bg-white border border-stone-200 rounded-lg shadow-lg max-h-96 overflow-y-auto hidden z-20"
  ></div>
</div>

<script type="application/json" id="search-index" set:html={JSON.stringify(index)} />

<script is:inline>
  (function () {
    const input = document.getElementById('search-input')
    const results = document.getElementById('search-results')
    const indexEl = document.getElementById('search-index')
    if (!input || !results || !indexEl) return
    const index = JSON.parse(indexEl.textContent || '[]')

    function escape(s) {
      return s.replace(/[&<>"']/g, c => ({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'}[c]))
    }

    function render(matches) {
      if (matches.length === 0) {
        results.innerHTML = '<div class="px-4 py-3 text-sm text-stone-400">没有匹配</div>'
        return
      }
      results.innerHTML = matches.slice(0, 8).map(m => `
        <a href="${m.status === 'generated' ? m.base : '#'}"
           class="flex items-start gap-3 px-3 py-2 hover:bg-stone-50 border-b border-stone-100 last:border-0 ${m.status !== 'generated' ? 'opacity-60' : ''}">
          <img src="${m.thumbnail}" class="w-16 h-9 object-cover rounded flex-shrink-0" loading="lazy" />
          <div class="flex-1 min-w-0">
            <div class="text-sm font-medium text-stone-900 truncate">${escape(m.title)}</div>
            <div class="text-xs text-stone-500 truncate">
              <span style="color: ${m.source_color}">●</span>
              ${escape(m.source)}${m.guest ? ' · ' + escape(m.guest) : ''}
            </div>
          </div>
        </a>
      `).join('')
    }

    function search(q) {
      q = q.trim().toLowerCase()
      if (!q) {
        results.classList.add('hidden')
        return
      }
      const tokens = q.split(/\s+/).filter(Boolean)
      const matches = index.filter(item =>
        tokens.every(t => item._hay.includes(t))
      )
      render(matches)
      results.classList.remove('hidden')
    }

    input.addEventListener('input', e => search(e.target.value))
    input.addEventListener('focus', e => { if (e.target.value) search(e.target.value) })

    // close on outside click
    document.addEventListener('click', e => {
      if (!document.getElementById('search-root').contains(e.target)) {
        results.classList.add('hidden')
      }
    })
    // ESC to close
    input.addEventListener('keydown', e => {
      if (e.key === 'Escape') {
        results.classList.add('hidden')
        input.blur()
      }
    })
  })()
</script>
